# Jira
JIRA_URL=https://your-company.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=AP

# Outline
OUTLINE_URL=https://your-outline.example.com
OUTLINE_API_TOKEN=your-outline-api-token
OUTLINE_COLLECTION_ID=your-outline-collection-id

# Agent
LOG_LEVEL=INFO
STATE_DIR=./state
OUTPUT_DIR=./output
